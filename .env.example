# This file contains environment variables for the MDB Agent Builder
# Copy this file to .env and modify as needed

# LLM API Keys
ANTHROPIC_API_KEY=
FIREWORKS_API_KEY=
COHERE_API_KEY=
TOGETHER_API_KEY=
VOYAGEAI_API_KEY=
# Google Gemini (Google AI Studio). Used by both `google`/`gemini` LLM and
# embedding providers. GEMINI_API_KEY is accepted as an alternative.
GOOGLE_API_KEY=

# Azure OpenAI (use the `azure` provider for OpenAI / GPT models)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=

# Grove API Gateway (OpenAI-compatible LLM gateway)
# GROVE_API_BASE is the gateway's base URL (e.g. https://grove.example.com/v1)
# GROVE_API_KEY is the gateway auth token (leave blank if the gateway is unauthenticated)
GROVE_API_BASE=
GROVE_API_KEY=

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=agent_builder

# Application Settings
LOG_LEVEL=INFO
# Generate a secure key: python3 -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=
AGENT_CONFIG_PATH=config/agents.yaml
# Required for admin endpoints (GET /threads, global POST /reset).
# Leave unset to disable admin operations entirely.
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
MDB_ADMIN_TOKEN=

# Checkpoint Configuration
CHECKPOINT_ENABLED=false
CHECKPOINT_PROVIDER=mongodb
CHECKPOINT_URI=${MONGODB_URI}
CHECKPOINT_DB=${MONGODB_DATABASE}
